<!-- Skulpt for Python -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/skulpt/1.2.0/skulpt.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/skulpt/1.2.0/skulpt-stdlib.js"></script>

<script>
// NAV
function show(id, el) {
  document.querySelectorAll('section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}

// PYTHON RUNNER (Skulpt)
function runPython(id) {
  const code = document.getElementById('code-' + id).value;
  const outEl = document.getElementById('out-' + id);
  outEl.style.color = '#22c55e';
  outEl.textContent = 'Menjalankan...';
  let output = '';

  Sk.configure({
    output: function(txt) { output += txt; },
    read: function(x) {
      if (Sk.builtinFiles && Sk.builtinFiles.files[x]) return Sk.builtinFiles.files[x];
      throw new Error("File not found: " + x);
    }
  });

  Sk.misceval.asyncToPromise(() => Sk.importMainWithBody('<stdin>', false, code, true))
    .then(() => { outEl.textContent = output || '(tidak ada output)'; })
    .catch(err => {
      outEl.style.color = '#f87171';
      outEl.textContent = 'Error: ' + err.toString();
    });
}

// UPLOAD CARDS
const tugasList = [
  {id:'t1', label:'Tugas 1', desc:'Perulangan For'},
  {id:'t2', label:'Tugas 2', desc:'Perulangan While'},
  {id:'t3', label:'Tugas 3', desc:'Perulangan Do-While'},
  {id:'t4', label:'Tugas 4', desc:'Nested Loop'},
  {id:'t5', label:'Tugas 5', desc:'Fungsi & Prosedur'},
  {id:'t6', label:'Tugas 6', desc:'Array (Larik)'},
  {id:'t7', label:'Tugas 7', desc:'Algoritma Skuensial'},
  {id:'t8', label:'Tugas 8', desc:'Tugas Gabungan / Bebas'},
];

const container = document.getElementById('upload-cards');
tugasList.forEach(t => {
  const card = document.createElement('div');
  card.className = 'card';
  card.style.marginBottom = '0.8rem';
  card.innerHTML = `
    <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:1rem">
      <div class="materi-num">${t.label.replace('Tugas ','')}</div>
      <div>
        <div class="materi-title">${t.label}</div>
        <div class="materi-sub">${t.desc}</div>
      </div>
      <div id="badge-${t.id}" style="margin-left:auto;font-size:0.7rem;font-weight:600;padding:3px 10px;border-radius:20px;background:#fef3c7;color:#b45309;">Belum Upload</div>
    </div>
    <div class="upload-slot" id="slot-${t.id}">
      <input type="file" id="file-${t.id}" onchange="handleFile('${t.id}')" accept=".py,.pdf,.doc,.docx,.txt,.zip">
      <span class="slot-icon">📂</span>
      <div class="slot-label">Klik untuk pilih file</div>
      <div class="slot-sub">.py · .pdf · .doc · .docx · .zip</div>
      <div class="slot-fname" id="fname-${t.id}"></div>
    </div>
    <button class="submit-btn" id="btn-${t.id}" onclick="submitFile('${t.id}')" disabled>Kumpulkan ${t.label}</button>
    <div class="success-msg" id="ok-${t.id}">✅ ${t.label} berhasil dikumpulkan!</div>
  `;
  container.appendChild(card);
});

function handleFile(id) {
  const f = document.getElementById('file-'+id).files[0];
  if (!f) return;
  document.getElementById('fname-'+id).textContent = f.name;
  document.getElementById('slot-'+id).classList.add('slot-done');
  document.getElementById('btn-'+id).disabled = false;
  document.getElementById('badge-'+id).textContent = 'File Dipilih';
  document.getElementById('ok-'+id).classList.remove('show');
}

function submitFile(id) {
  const btn = document.getElementById('btn-'+id);
  btn.textContent = 'Mengumpulkan...';
  btn.disabled = true;
  setTimeout(() => {
    document.getElementById('ok-'+id).classList.add('show');
    const badge = document.getElementById('badge-'+id);
    badge.textContent = 'Dikumpulkan ✓';
    badge.style.background = '#dcfce7';
    badge.style.color = '#166534';
    btn.style.display = 'none';
  }, 1200);
}
</script>
</body>
</html>
