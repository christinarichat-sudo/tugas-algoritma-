<title>Tugas Algoritma Pemrograman</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0f1729;
  --indigo: #1e2d6e;
  --violet: #3a3faa;
  --accent: #f0a500;
  --green: #22c55e;
  --red: #ef4444;
  --soft: #e8e9f8;
  --cream: #f4f5fb;
  --white: #ffffff;
  --gray: #6b7280;
  --border: #e2e4f0;
  --code-bg: #0d1117;
  --code-text: #e6edf3;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'DM Sans',sans-serif; background:var(--cream); color:#1a1a2e; min-height:100vh; }

/* NAV */
nav {
  background:var(--navy);
  display:flex; align-items:center;
  padding:0 1rem;
  position:sticky; top:0; z-index:100;
  box-shadow:0 2px 20px rgba(0,0,0,0.3);
  overflow-x:auto; scrollbar-width:none;
  gap:2px;
}
nav::-webkit-scrollbar{display:none;}
.nav-brand {
  font-family:'Syne',sans-serif; font-weight:800;
  color:var(--white); font-size:0.85rem;
  white-space:nowrap; padding:1rem 0.8rem 1rem 0;
  margin-right:0.5rem; border-right:1px solid rgba(255,255,255,0.1);
}
.nav-brand span{color:var(--accent);}
.nav-tab {
  padding:1rem 0.9rem; font-size:0.78rem; font-weight:500;
  color:rgba(255,255,255,0.5); cursor:pointer; white-space:nowrap;
  border-bottom:2.5px solid transparent; transition:all 0.2s;
}
.nav-tab:hover{color:var(--white);}
.nav-tab.active{color:var(--white); border-bottom-color:var(--accent);}

/* HERO */
.hero {
  background:linear-gradient(135deg,var(--navy) 0%,var(--indigo) 70%,#2a2f8a 100%);
  padding:3rem 2rem 2rem; position:relative; overflow:hidden;
}
.hero::before {
  content:''; position:absolute;
  width:500px; height:500px; border-radius:50%;
  background:rgba(255,255,255,0.03);
  top:-150px; right:-100px;
}
.hero-title {
  font-family:'Syne',sans-serif; font-weight:800;
  font-size:2.2rem; color:var(--white); line-height:1.1;
  margin-bottom:0.5rem;
}
.hero-title span{color:var(--accent);}
.hero-sub{color:rgba(255,255,255,0.5); font-size:0.85rem; font-style:italic;}

/* SECTIONS */
section{display:none; animation:fadeIn 0.3s ease;}
section.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.container{max-width:760px; margin:0 auto; padding:2rem 1.2rem 4rem;}

/* CARDS */
.card {
  background:var(--white); border-radius:14px; padding:1.6rem;
  margin-bottom:1rem; border:1px solid var(--border);
  box-shadow:0 2px 10px rgba(26,31,78,0.06);
}
.card h2{font-family:'Syne',sans-serif; font-size:1.3rem; font-weight:700; color:var(--navy); margin-bottom:1rem;}
.card h3{font-family:'Syne',sans-serif; font-size:1rem; font-weight:700; color:var(--navy); margin-bottom:0.8rem;}
.card p{font-size:0.88rem; color:#4a4a6a; line-height:1.75; margin-bottom:0.6rem;}
.card p:last-child{margin-bottom:0;}

/* STUDENT CARD */
.student-card {
  background:linear-gradient(135deg,var(--navy),var(--indigo));
  border-radius:14px; padding:1.6rem; margin-bottom:1rem;
  color:var(--white); position:relative; overflow:hidden;
}
.student-card::before{
  content:''; position:absolute;
  width:200px; height:200px; border-radius:50%;
  background:rgba(255,255,255,0.04);
  top:-60px; right:-40px;
}
.sc-label{font-size:0.62rem; font-weight:600; letter-spacing:3px; text-transform:uppercase; color:rgba(255,255,255,0.4); margin-bottom:0.8rem;}
.sc-name{font-family:'Syne',sans-serif; font-size:1.5rem; font-weight:800; margin-bottom:1rem; line-height:1.1;}
.sc-name span{color:var(--accent);}
.sc-rows{display:flex; gap:1.5rem; flex-wrap:wrap;}
.sc-row .key{font-size:0.6rem; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:2px;}
.sc-row .val{font-size:0.85rem; font-weight:500;}

/* TOC */
.toc-item{display:flex; align-items:flex-start; gap:0.8rem; padding:0.75rem 0; border-bottom:1px solid var(--border);}
.toc-item:last-child{border-bottom:none; padding-bottom:0;}
.toc-badge{background:var(--soft); color:var(--indigo); font-family:'Syne',sans-serif; font-size:0.68rem; font-weight:700; padding:3px 7px; border-radius:5px; white-space:nowrap; margin-top:1px;}
.toc-title{font-weight:600; font-size:0.85rem; color:var(--navy); margin-bottom:1px;}
.toc-desc{font-size:0.75rem; color:var(--gray);}

/* MATERI SECTION */
.materi-header{display:flex; align-items:center; gap:0.8rem; margin-bottom:1.2rem;}
.materi-num{width:38px; height:38px; border-radius:10px; background:linear-gradient(135deg,var(--indigo),var(--violet)); color:var(--white); font-family:'Syne',sans-serif; font-weight:700; font-size:0.85rem; display:flex; align-items:center; justify-content:center;}
.materi-title{font-family:'Syne',sans-serif; font-weight:700; font-size:1.1rem; color:var(--navy);}
.materi-sub{font-size:0.75rem; color:var(--gray);}

/* CODE EDITOR */
.code-editor{background:var(--code-bg); border-radius:10px; overflow:hidden; margin:1rem 0;}
.code-toolbar{display:flex; align-items:center; justify-content:space-between; padding:0.6rem 1rem; background:#161b22; border-bottom:1px solid #30363d;}
.code-lang{font-family:'DM Mono',monospace; font-size:0.72rem; color:#8b949e;}
.code-dots{display:flex; gap:5px;}
.dot{width:10px; height:10px; border-radius:50%;}
.dot-r{background:#ff5f56;} .dot-y{background:#ffbd2e;} .dot-g{background:#27c93f;}
.code-area{
  width:100%; background:transparent; border:none; outline:none;
  color:var(--code-text); font-family:'DM Mono',monospace; font-size:0.8rem;
  line-height:1.6; padding:1rem; resize:vertical; min-height:160px;
}
.run-btn{
  width:100%; padding:0.7rem; background:linear-gradient(135deg,#22c55e,#16a34a);
  color:var(--white); border:none; border-radius:0 0 10px 10px;
  font-family:'Syne',sans-serif; font-weight:600; font-size:0.85rem;
  cursor:pointer; transition:all 0.2s; letter-spacing:0.5px;
}
.run-btn:hover{opacity:0.9;}

.output-box{
  background:#0d1117; border-radius:10px; padding:1rem;
  font-family:'DM Mono',monospace; font-size:0.8rem;
  color:#22c55e; min-height:60px; margin-top:0.5rem;
  white-space:pre-wrap; border:1px solid #21262d;
}
.output-label{font-size:0.68rem; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:0.4rem;}

/* UPLOAD */
.upload-section{margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);}
.upload-grid{display:grid; grid-template-columns:1fr 1fr; gap:0.8rem;}
.upload-slot{
  border:2px dashed var(--border); border-radius:10px;
  padding:1rem; text-align:center; cursor:pointer;
  transition:all 0.2s; background:var(--cream); position:relative;
}
.upload-slot:hover{border-color:var(--violet); background:var(--soft);}
.upload-slot input{position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%;}
.slot-icon{font-size:1.4rem; display:block; margin-bottom:4px;}
.slot-label{font-family:'Syne',sans-serif; font-weight:700; font-size:0.75rem; color:var(--navy);}
.slot-sub{font-size:0.68rem; color:var(--gray);}
.slot-done{border-color:var(--green); background:#f0fdf4;}
.slot-done .slot-label{color:#166534;}
.slot-fname{font-size:0.68rem; color:#16a34a; margin-top:3px; word-break:break-all;}

/* SUBMIT */
.submit-btn{
  width:100%; margin-top:0.8rem; padding:0.7rem;
  background:linear-gradient(135deg,var(--navy),var(--indigo));
  color:var(--white); border:none; border-radius:10px;
  font-family:'Syne',sans-serif; font-weight:600; font-size:0.82rem;
  cursor:pointer; transition:all 0.2s;
}
.submit-btn:hover{opacity:0.9; transform:translateY(-1px);}
.submit-btn:disabled{opacity:0.4; cursor:not-allowed; transform:none;}
.success-msg{display:none; text-align:center; font-size:0.8rem; color:#166534; font-weight:600; margin-top:0.5rem; padding:0.5rem; background:#dcfce7; border-radius:8px;}
.success-msg.show{display:block;}

/* HERO ONLY */
.hero-only {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  min-height:60vh; text-align:center;
  background:linear-gradient(135deg,var(--navy) 0%,var(--indigo) 70%,#2a2f8a 100%);
  padding:4rem 2rem; position:relative; overflow:hidden;
}
.hero-only::before{
  content:''; position:absolute; width:600px; height:600px; border-radius:50%;
  background:rgba(255,255,255,0.03); top:-200px; right:-150px;
}
.hero-only::after{
  content:''; position:absolute; width:300px; height:300px; border-radius:50%;
  background:rgba(255,255,255,0.03); bottom:-100px; left:-50px;
}
.hero-only h1{font-family:'Syne',sans-serif; font-weight:800; font-size:2.8rem; color:var(--white); line-height:1.1; margin-bottom:1rem; position:relative;}
.hero-only h1 span{color:var(--accent);}
.hero-only p{color:rgba(255,255,255,0.55); font-size:1rem; font-style:italic; position:relative;}
.hero-only .badge{
  display:inline-block; background:rgba(240,165,0,0.15); border:1px solid rgba(240,165,0,0.3);
  color:var(--accent); font-size:0.72rem; font-weight:600; letter-spacing:2px;
  text-transform:uppercase; padding:5px 14px; border-radius:20px;
  margin-bottom:1.5rem; position:relative;
}
</style>
</head>
