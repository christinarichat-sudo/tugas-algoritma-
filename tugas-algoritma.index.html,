<!-- T1 FOR -->
<section id="m1">
  <div class="container">
    <div class="card">
      <div class="materi-header">
        <div class="materi-num">T1</div>
        <div><div class="materi-title">Perulangan For</div><div class="materi-sub">Iterasi dengan range dan koleksi data</div></div>
      </div>
      <p>Perulangan <strong>for</strong> digunakan untuk mengulang blok kode sejumlah tertentu, biasanya iterasi atas urutan (list, range, string).</p>
      <p><strong>Pseudocode:</strong></p>
      <div class="code-editor">
        <div class="code-toolbar"><div class="code-dots"><div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div></div><span class="code-lang">Pseudocode</span></div>
        <textarea class="code-area" readonly style="min-height:80px">UNTUK i DARI 1 SAMPAI 10:
    TAMPILKAN i
AKHIR UNTUK</textarea>
      </div>
      <p style="margin-top:0.8rem"><strong>Program Python — coba jalankan:</strong></p>
      <div class="code-editor">
        <div class="code-toolbar"><div class="code-dots"><div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div></div><span class="code-lang">Python</span></div>
        <textarea class="code-area" id="code-m1"># Contoh 1: For loop dengan range
print("=== Perulangan For ===")
for i in range(1, 11):
    print(f"Angka ke-{i}: {i}")

# Contoh 2: For loop dengan list
print("\n=== Iterasi List Buah ===")
buah = ["apel", "mangga", "jeruk", "pisang"]
for item in buah:
    print(f"- {item}")

# Contoh 3: Jumlah total
print("\n=== Jumlah 1 sampai 10 ===")
total = 0
for i in range(1, 11):
    total += i
print(f"Total = {total}")</textarea>
        <button class="run-btn" onclick="runPython('m1')">▶ Jalankan Program</button>
      </div>
      <div class="output-label">Output:</div>
      <div class="output-box" id="out-m1">Klik "Jalankan Program" untuk melihat hasil...</div>
    </div>
